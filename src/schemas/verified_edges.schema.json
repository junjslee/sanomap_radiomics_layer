{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EdgeCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "pmid",
    "radiomic_feature",
    "subject_node_type",
    "subject_node",
    "object_node_type",
    "object_node",
    "graph_rel_type",
    "relation_type",
    "evidence_type",
    "confidence",
    "evidence",
    "verification_passed",
    "assertion_level"
  ],
  "properties": {
    "edge_id": {"type": "string"},
    "pmid": {"type": "string"},
    "microbe": {"type": ["string", "null"]},
    "radiomic_feature": {"type": "string"},
    "disease": {"type": ["string", "null"]},
    "subject_node_type": {
      "type": "string",
      "enum": ["Microbe", "MicrobialSignature", "RadiomicFeature", "BodyCompositionFeature"]
    },
    "subject_node": {"type": "string"},
    "object_node_type": {
      "type": "string",
      "enum": ["RadiomicFeature", "BodyCompositionFeature", "Disease"]
    },
    "object_node": {"type": "string"},
    "graph_rel_type": {
      "type": "string",
      "enum": ["CORRELATES_WITH", "ASSOCIATED_WITH"]
    },
    "relation_type": {"type": "string"},
    "r_value": {"type": ["number", "null"]},
    "evidence_type": {"type": "string"},
    "confidence": {"type": "number"},
    "figure_id": {"type": ["string", "null"]},
    "journal": {"type": ["string", "null"]},
    "title": {"type": ["string", "null"]},
    "pmcid": {"type": ["string", "null"]},
    "publication_year": {"type": ["integer", "null"]},
    "impact_factor": {"type": ["number", "null"]},
    "quartile": {"type": ["string", "null"]},
    "issn": {"type": ["string", "null"]},
    "evidence": {"type": "string"},
    "verification_passed": {"type": "boolean"},
    "feature_family": {
      "type": ["string", "null"],
      "enum": ["radiomic", "body_composition", null]
    },
    "claim_hint": {
      "type": ["string", "null"],
      "enum": ["association", "predictive", "diagnostic", "prognostic", null]
    },
    "assertion_level": {
      "type": "string",
      "enum": ["direct_evidence"]
    }
  }
}
