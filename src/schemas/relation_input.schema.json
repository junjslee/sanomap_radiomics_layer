{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RelationInputRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "row_id",
    "pmid",
    "sentence",
    "microbe",
    "disease",
    "subject_node_type",
    "subject_node"
  ],
  "properties": {
    "row_id": {"type": "string"},
    "pmid": {"type": "string"},
    "sentence": {"type": "string"},
    "microbe": {"type": "string"},
    "disease": {"type": "string"},
    "subject_node_type": {
      "type": "string",
      "enum": ["Microbe", "MicrobialSignature"]
    },
    "subject_node": {"type": "string"},
    "impact_factor": {"type": ["number", "null"]},
    "quartile": {"type": ["string", "null"]},
    "entity_sentence_id": {"type": ["string", "null"]},
    "disease_cui": {"type": ["string", "null"]},
    "microbe_cui": {"type": ["string", "null"]},
    "radiomic_features": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "has_radiomics_context": {"type": ["boolean", "null"]},
    "source": {"type": ["string", "null"]}
  }
}
