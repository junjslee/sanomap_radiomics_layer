{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PhenotypeAxisCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "mention_id",
    "pmid",
    "subject_node_type",
    "subject_node",
    "phenotype",
    "phenotype_node_type",
    "feature_family",
    "disease_context",
    "evidence",
    "confidence",
    "claim_hint",
    "not_for_graph_ingestion"
  ],
  "properties": {
    "candidate_id": {"type": "string"},
    "mention_id": {"type": "string"},
    "pmid": {"type": "string"},
    "subject_node_type": {
      "type": "string",
      "enum": ["Microbe", "MicrobialSignature"]
    },
    "subject_node": {"type": "string"},
    "phenotype": {"type": "string"},
    "phenotype_node_type": {
      "type": "string",
      "enum": ["RadiomicFeature", "BodyCompositionFeature"]
    },
    "feature_family": {
      "type": "string",
      "enum": ["radiomic", "body_composition"]
    },
    "disease_context": {"type": ["string", "null"]},
    "evidence": {"type": "string"},
    "confidence": {"type": "number"},
    "claim_hint": {
      "type": ["string", "null"],
      "enum": ["association", "predictive", "diagnostic", "prognostic", null]
    },
    "not_for_graph_ingestion": {"type": "boolean"}
  }
}
