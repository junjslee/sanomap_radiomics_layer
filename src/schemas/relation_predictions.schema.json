{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RelationPrediction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prediction_id",
    "pmid",
    "microbe",
    "subject_node_type",
    "subject_node",
    "disease",
    "sentence",
    "final_label",
    "accepted",
    "full_consistency",
    "label_entropy",
    "zero_entropy",
    "sample_labels",
    "vote_counts",
    "model_backend",
    "model_family",
    "model_id",
    "temperatures"
  ],
  "properties": {
    "prediction_id": {"type": "string"},
    "pmid": {"type": "string"},
    "microbe": {"type": "string"},
    "subject_node_type": {
      "type": "string",
      "enum": ["Microbe", "MicrobialSignature"]
    },
    "subject_node": {"type": "string"},
    "disease": {"type": "string"},
    "sentence": {"type": "string"},
    "final_label": {"type": "string", "enum": ["positive", "negative", "unrelated"]},
    "accepted": {"type": "boolean"},
    "full_consistency": {"type": "boolean"},
    "label_entropy": {"type": "number"},
    "zero_entropy": {"type": "boolean"},
    "sample_labels": {
      "type": "array",
      "items": {"type": "string", "enum": ["positive", "negative", "unrelated"]}
    },
    "vote_counts": {"type": "object"},
    "model_backend": {"type": "string"},
    "model_family": {"type": "string"},
    "model_id": {"type": "string"},
    "temperatures": {
      "type": "array",
      "items": {"type": "number"}
    },
    "impact_factor": {"type": ["number", "string", "null"]},
    "quartile": {"type": ["number", "string", "null"]}
  }
}
