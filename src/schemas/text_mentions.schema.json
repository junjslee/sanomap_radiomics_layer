{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RadiomicMention",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mention_id",
    "pmid",
    "sentence",
    "span_start",
    "span_end",
    "raw_feature",
    "canonical_feature",
    "ibsi_id",
    "confidence",
    "mapping_method",
    "evidence",
    "feature_family",
    "node_type",
    "ontology_namespace"
  ],
  "properties": {
    "mention_id": {"type": "string"},
    "pmid": {"type": "string"},
    "sentence": {"type": "string"},
    "span_start": {"type": "integer"},
    "span_end": {"type": "integer"},
    "raw_feature": {"type": "string"},
    "canonical_feature": {"type": "string"},
    "ibsi_id": {"type": "string"},
    "confidence": {"type": "number"},
    "mapping_method": {"type": "string"},
    "evidence": {"type": "string"},
    "feature_family": {
      "type": "string",
      "enum": ["radiomic", "body_composition"]
    },
    "node_type": {
      "type": "string",
      "enum": ["RadiomicFeature", "BodyCompositionFeature"]
    },
    "ontology_namespace": {
      "type": "string",
      "enum": ["IBSI", "BODYCOMP"]
    },
    "modality": {"type": ["string", "null"]},
    "body_location": {"type": ["string", "null"]},
    "disease": {"type": ["string", "null"]},
    "claim_hint": {
      "type": ["string", "null"],
      "enum": ["association", "predictive", "diagnostic", "prognostic", null]
    },
    "subject_node_type": {
      "type": ["string", "null"],
      "enum": ["Microbe", "MicrobialSignature", null]
    },
    "subject_node": {"type": ["string", "null"]}
  }
}
